                               rdfs:subClassOf [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalSituationStatement>
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#representsSituation> ;
                                                                        owl:someValuesFrom <http://snomed.info/id/704417003>
                                                                      ]
                                                                    ) ;
                                                 rdf:type owl:Class
                                               ] ;
                               rdfs:comment "Modeled in the ontology as a clinical-situation statement whose represented situation is the SNOMED CT concept \"At increased risk of medication side effect (finding)\"."@en ;
                               skos:altLabel "Medication Side Effects"@en .


###  http://www.semanticweb.org/catimc/resqplus#MentalState
resqplus:MentalState rdf:type owl:Class ;
                     rdfs:subClassOf [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalSituationStatement>
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#representsSituation> ;
                                                              owl:someValuesFrom <http://snomed.info/id/36456004>
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                     rdfs:comment "Modeled in the ontology as a clinical-situation statement whose represented situation is the SNOMED CT concept \"Mental state finding (finding)\"."@en ;
                     skos:altLabel "Mental State"@en .


###  http://www.semanticweb.org/catimc/resqplus#MildDeficit
resqplus:MildDeficit rdf:type owl:Class ;
                     rdfs:subClassOf [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalSituationPresentStatement>
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#representsSituation> ;
                                                              owl:someValuesFrom [ owl:intersectionOf ( <http://snomed.info/id/230690007>
                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                          owl:onProperty <http://snomed.info/id/246112005> ;
                                                                                                          owl:someValuesFrom <http://snomed.info/id/255604002>
                                                                                                        ]
                                                                                                      ) ;
                                                                                   rdf:type owl:Class
                                                                                 ]
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                     rdfs:comment "Modeled in the ontology as a clinical situation present statement whose represented situation is the SNOMED CT concept \"Cerebrovascular accident (disorder)\" whose severity is the SNOMED CT concept \"Mild (qualifier value)\"."@en ;
                     skos:altLabel "Mild Deficit"@en .


###  http://www.semanticweb.org/catimc/resqplus#MinInvasiveEvacuation
resqplus:MinInvasiveEvacuation rdf:type owl:Class ;
                               rdfs:subClassOf [ owl:intersectionOf ( <http://snomed.info/id/10458001>
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <http://snomed.info/id/609096000> ;
                                                                        owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                                             owl:onProperty <http://snomed.info/id/424226004> ;
                                                                                             owl:someValuesFrom <http://snomed.info/id/19923001>
                                                                                           ]
                                                                      ]
                                                                    ) ;
                                                 rdf:type owl:Class
                                               ] ;
                               rdfs:comment "Modeled in the ontology as the SNOMED CT concept \"Evacuation of intracerebral hematoma (procedure)\" whose role group is something whose using device is the SNOMED CT concept \"Catheter, device (physical object)\"."@en ;
                               skos:altLabel "Min Invasive Evacuation"@en .


###  http://www.semanticweb.org/catimc/resqplus#MobileAppFollowUP
resqplus:MobileAppFollowUP rdf:type owl:Class ;
                           rdfs:subClassOf <http://snomed.info/id/71388002> ;
                           rdfs:comment "A subclass of the SNOMED CT concept \"Procedure (procedure)\" (code 71388002), reusing the SNOMED CT term without further specification in the ontology."@en ;
                           skos:altLabel "Mobile App Follow UP"@en .


###  http://www.semanticweb.org/catimc/resqplus#ModerateCarotidStenosis
resqplus:ModerateCarotidStenosis rdf:type owl:Class ;
                                 rdfs:subClassOf resqplus:CarotidStenosisDegreeValue ;
                                 rdfs:comment "A more specific subtype of a carotid stenosis degree value within the RES-Q+ ontology, with no additional restrictions."@en ,
                                              "50% -70%" ;
                                 skos:altLabel "Moderate Carotid Stenosis"@en .


###  http://www.semanticweb.org/catimc/resqplus#ModifiedRankinScaleScoreAtDischarge
resqplus:ModifiedRankinScaleScoreAtDischarge rdf:type owl:Class ;
                                             rdfs:subClassOf [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement>
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservable> ;
                                                                                      owl:someValuesFrom resqplus:ModifiedRankinScaleScoreAtDischargeObservable
                                                                                    ]
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservableValue> ;
                                                                                      owl:someValuesFrom resqplus:mRSValueSet
                                                                                    ]
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                                                      owl:someValuesFrom <http://snomed.info/id/58000006>
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ;
                                             rdfs:comment "Value of modified Rankin Scale (mRS) at discharge (6 in case of death)."@en ;
                                             skos:altLabel "Modified rankin scale score at discharge"@en .


###  http://www.semanticweb.org/catimc/resqplus#ModifiedRankinScaleScoreAtDischargeObservable
resqplus:ModifiedRankinScaleScoreAtDischargeObservable rdf:type owl:Class ;
                                                       rdfs:subClassOf <http://snomed.info/id/1255866005> ;
                                                       rdfs:comment "A subclass of the SNOMED CT concept \"Modified Rankin Scale score (observable entity)\" (code 1255866005), reusing the SNOMED CT term without further specification in the ontology."@en ;
                                                       skos:altLabel "Modified Rankin Scale Score At Discharge Observable"@en .


###  http://www.semanticweb.org/catimc/resqplus#ModifiedRankinScaleScoreAtFollowUpObservable
resqplus:ModifiedRankinScaleScoreAtFollowUpObservable rdf:type owl:Class ;
                                                      rdfs:subClassOf <http://snomed.info/id/1255866005> ;
                                                      rdfs:comment "A subclass of the SNOMED CT concept \"Modified Rankin Scale score (observable entity)\" (code 1255866005), reusing the SNOMED CT term without further specification in the ontology."@en ;
                                                      skos:altLabel "Modified Rankin Scale Score At Follow Up Observable"@en .


###  http://www.semanticweb.org/catimc/resqplus#NIHSSScoreAtDischarge
resqplus:NIHSSScoreAtDischarge rdf:type owl:Class ;
                               rdfs:subClassOf [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement>
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservable> ;
                                                                        owl:someValuesFrom resqplus:NIHSSScoreAtDischargeObservable
                                                                      ]
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservableValue> ;
                                                                        owl:someValuesFrom [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#QuantitativeResultValue>
                                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                                    owl:onProperty <http://purl.org/biotop/btl2.owl#hasValue> ;
                                                                                                                    owl:someValuesFrom xsd:integer
                                                                                                                  ]
                                                                                                                ) ;
                                                                                             rdf:type owl:Class
                                                                                           ]
                                                                      ]
                                                                      [ rdf:type owl:Restriction ;
                                                                        owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                                        owl:someValuesFrom resqplus:PostAcuteCareProcedure
                                                                      ]
                                                                    ) ;
                                                 rdf:type owl:Class
                                               ] ;
                               rdfs:comment "Value of  National Institutes of Health Stroke Scale (NIHSS) at discharge from reporting hospital."@en ;
                               skos:altLabel "NIHSS score at discharge"@en .


###  http://www.semanticweb.org/catimc/resqplus#NIHSSScoreAtDischargeObservable
resqplus:NIHSSScoreAtDischargeObservable rdf:type owl:Class ;
                                         rdfs:subClassOf <http://snomed.info/id/450743008> ;
                                         rdfs:comment "A subclass of the SNOMED CT concept \"National Institutes of Health stroke scale score (observable entity)\" (code 450743008), reusing the SNOMED CT term without further specification in the ontology."@en ;
                                         skos:altLabel "NIHSS Score At Discharge Observable"@en .


###  http://www.semanticweb.org/catimc/resqplus#NameTransferredStrokeCenter
resqplus:NameTransferredStrokeCenter rdf:type owl:Class ;
                                     rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement> ,
                                                     [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement>
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservable> ;
                                                                              owl:someValuesFrom resqplus:NameTransferredStrokeCenterObservable
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservableValue> ;
                                                                              owl:someValuesFrom [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#QuantitativeResultValue>
                                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                                          owl:onProperty <http://purl.org/biotop/btl2.owl#hasValue> ;
                                                                                                                          owl:someValuesFrom xsd:string
                                                                                                                        ]
                                                                                                                      ) ;
                                                                                                   rdf:type owl:Class
                                                                                                 ]
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                                              owl:someValuesFrom <http://snomed.info/id/32485007>
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#situationContext> ;
                                                                              owl:someValuesFrom resqplus:StatementFindingQualifierValueSet
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#temporalContext> ;
                                                                              owl:someValuesFrom <http://snomed.info/id/410511007>
                                                                            ]
                                                                          ) ;
                                                       rdf:type owl:Class
                                                     ] ;
                                     rdfs:comment "The name of the stroke centre from which patient was transferred."@en ;
                                     skos:altLabel "Name transferred stroke center"@en .


