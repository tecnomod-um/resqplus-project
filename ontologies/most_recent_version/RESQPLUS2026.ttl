###  http://www.semanticweb.org/catimc/resqplus#BleedingVolume
resqplus:BleedingVolume rdf:type owl:Class ;
                        rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement> ,
                                        [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement>
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservable> ;
                                                                 owl:someValuesFrom <http://snomed.info/id/16086006>
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservableValue> ;
                                                                 owl:someValuesFrom [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#QuantitativeResultValue>
                                                                                                           [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty <http://purl.org/biotop/btl2.owl#hasValue> ;
                                                                                                             owl:someValuesFrom xsd:integer
                                                                                                           ]
                                                                                                         ) ;
                                                                                      rdf:type owl:Class
                                                                                    ]
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                                 owl:someValuesFrom [ owl:intersectionOf ( resqplus:BrainBloodVolumeEstimationAfterICH
                                                                                                           [ rdf:type owl:Restriction ;
                                                                                                             owl:onProperty <http://purl.org/biotop/btl2.owl#isPartOf> ;
                                                                                                             owl:someValuesFrom resqplus:PostAcuteCareProcedure
                                                                                                           ]
                                                                                                         ) ;
                                                                                      rdf:type owl:Class
                                                                                    ]
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#situationContext> ;
                                                                 owl:someValuesFrom resqplus:StatementFindingQualifierValueSet
                                                               ]
                                                               [ rdf:type owl:Restriction ;
                                                                 owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#temporalContext> ;
                                                                 owl:someValuesFrom <http://snomed.info/id/410511007>
                                                               ]
                                                             ) ;
                                          rdf:type owl:Class
                                        ] ;
                        rdfs:comment "The volume of blood, in milliliters, accumulated in brain tissue as a result of an intracerebral hemorrhage, measured at baseline or at a later control imaging."@en ;
                        skos:altLabel "Bleeding volume"@en .


