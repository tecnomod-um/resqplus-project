<http://snomed.info/id/265937000> rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#HealthcareProfessionalRole> .


###  http://snomed.info/id/281380002
<http://snomed.info/id/281380002> rdf:type owl:Class .


###  http://snomed.info/id/281381003
<http://snomed.info/id/281381003> rdf:type owl:Class .


###  http://snomed.info/id/305349003
<http://snomed.info/id/305349003> owl:equivalentClass resqplus:AdmissionToOtherDepartment .


###  http://snomed.info/id/308283009
<http://snomed.info/id/308283009> rdf:type owl:Class .


###  http://snomed.info/id/309343006
<http://snomed.info/id/309343006> rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#HealthcareProfessionalRole> .


###  http://snomed.info/id/37729005
<http://snomed.info/id/37729005> owl:equivalentClass resqplus:PatientTransferOtherHospitalDepartment .


###  http://snomed.info/id/385651009
<http://snomed.info/id/385651009> rdf:type owl:Class .


###  http://snomed.info/id/410536001
<http://snomed.info/id/410536001> rdf:type owl:Class .


###  http://snomed.info/id/5154007
<http://snomed.info/id/5154007> rdf:type owl:Class .


###  http://snomed.info/id/58920005
<http://snomed.info/id/58920005> rdf:type owl:Class .


###  http://snomed.info/id/709541000
<http://snomed.info/id/709541000> rdf:type owl:Class .


###  http://snomed.info/id/84478008
<http://snomed.info/id/84478008> rdf:type owl:Class .


###  http://snomed.info/id/897015005
<http://snomed.info/id/897015005> rdf:type owl:Class .


###  http://snomed.info/id/91251008
<http://snomed.info/id/91251008> rdf:type owl:Class .


###  http://www.semanticweb.org/catimc/resqplus#ASPECTScore
resqplus:ASPECTScore rdf:type owl:Class ;
                     rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement> ,
                                     [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservable> ;
                                                              owl:someValuesFrom <http://snomed.info/id/1290004001>
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservableValue> ;
                                                              owl:someValuesFrom [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#QuantitativeResultValue>
                                                                                                        [ rdf:type owl:Restriction ;
                                                                                                          owl:onProperty <http://purl.org/biotop/btl2.owl#hasValue> ;
                                                                                                          owl:someValuesFrom xsd:integer
                                                                                                        ]
                                                                                                      ) ;
                                                                                   rdf:type owl:Class
                                                                                 ]
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                              owl:someValuesFrom <http://snomed.info/id/445536008>
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#situationContext> ;
                                                              owl:someValuesFrom resqplus:StatementFindingQualifierValueSet
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#temporalContext> ;
                                                              owl:someValuesFrom <http://snomed.info/id/410511007>
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                     rdfs:comment "Value of ASPECTS score."@en ;
                     skos:altLabel "ASPECT score"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdministrationIVAntihypertensiveFocusHemStroke
resqplus:AdministrationIVAntihypertensiveFocusHemStroke rdf:type owl:Class ;
                                                        rdfs:subClassOf <http://snomed.info/id/433590000> ,
                                                                        [ owl:intersectionOf ( <http://snomed.info/id/433590000>
                                                                                               [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                                        owl:onProperty <http://snomed.info/id/363702006> ;
                                                                                                                        owl:someValuesFrom <http://snomed.info/id/230706003>
                                                                                                                      ]
                                                                                                                      [ rdf:type owl:Restriction ;
                                                                                                                        owl:onProperty <http://snomed.info/id/609096000> ;
                                                                                                                        owl:someValuesFrom [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                                                                                    owl:onProperty <http://snomed.info/id/363701004> ;
                                                                                                                                                                    owl:someValuesFrom <http://snomed.info/id/372586001>
                                                                                                                                                                  ]
                                                                                                                                                                  [ rdf:type owl:Restriction ;
                                                                                                                                                                    owl:onProperty <http://snomed.info/id/410675002> ;
                                                                                                                                                                    owl:someValuesFrom <http://snomed.info/id/47625008>
                                                                                                                                                                  ]
                                                                                                                                                                ) ;
                                                                                                                                             rdf:type owl:Class
                                                                                                                                           ]
                                                                                                                      ]
                                                                                                                    ) ;
                                                                                                 rdf:type owl:Class
                                                                                               ]
                                                                                             ) ;
                                                                          rdf:type owl:Class
                                                                        ] ;
                                                        rdfs:comment "Modeled in the ontology as SNOMED CT concept 433590000 whose focus is the SNOMED CT concept \"Hemorrhagic cerebral infarction (disorder)\"; and whose role group is an entity whose direct substance is the SNOMED CT concept \"Hypotensive agent (substance)\"; and whose route of administration is the SNOMED CT concept \"Intravenous route (qualifier value)\"."@en ;
                                                        skos:altLabel "Administration IV Antihypertensive Focus Hem Stroke"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdministrationInsulinOnHyperglycemia
resqplus:AdministrationInsulinOnHyperglycemia rdf:type owl:Class ;
                                              rdfs:subClassOf <http://snomed.info/id/39543009> ;
                                              rdfs:comment "A subclass of the SNOMED CT concept \"Administration of insulin (procedure)\" (code 39543009), reusing the SNOMED CT term without further specification in the ontology."@en ;
                                              skos:altLabel "Administration Insulin On Hyperglycemia"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdministrationOralNOAC
resqplus:AdministrationOralNOAC rdf:type owl:Class ;
                                rdfs:subClassOf <http://snomed.info/id/433590000> ,
                                                [ owl:intersectionOf ( <http://snomed.info/id/433590000>
                                                                       [ rdf:type owl:Restriction ;
                                                                         owl:onProperty <http://snomed.info/id/609096000> ;
                                                                         owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                                              owl:onProperty <http://snomed.info/id/363701004> ;
                                                                                              owl:someValuesFrom <http://snomed.info/id/385577009>
                                                                                            ]
                                                                       ]
                                                                     ) ;
                                                  rdf:type owl:Class
                                                ] ;
                                rdfs:comment "Modeled in the ontology as SNOMED CT concept 433590000 whose role group is something whose direct substance is the SNOMED CT concept \"Substance with coagulation factor Xa inhibitor mechanism of action (substance)\"."@en ;
                                skos:altLabel "Administration Oral NOAC"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionAge
resqplus:AdmissionAge rdf:type owl:Class ;
                      rdfs:subClassOf [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement>
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservable> ;
                                                               owl:someValuesFrom <http://snomed.info/id/445518008>
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservableValue> ;
                                                               owl:someValuesFrom [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#QuantitativeResultValue>
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty <http://purl.org/biotop/btl2.owl#hasValue> ;
                                                                                                           owl:someValuesFrom xsd:integer
                                                                                                         ]
                                                                                                       ) ;
                                                                                    rdf:type owl:Class
                                                                                  ]
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                               owl:someValuesFrom <http://snomed.info/id/32485007>
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#situationContext> ;
                                                               owl:someValuesFrom resqplus:StatementFindingQualifierValueSet
                                                             ]
                                                             [ rdf:type owl:Restriction ;
                                                               owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#temporalContext> ;
                                                               owl:someValuesFrom <http://snomed.info/id/410511007>
                                                             ]
                                                           ) ;
                                        rdf:type owl:Class
                                      ] ;
                      rdfs:comment "Age of stroke patient at onset of the stroke symptoms."@en ;
                      skos:altLabel "Admission age"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionArrivalEmergencyDepartment
resqplus:AdmissionArrivalEmergencyDepartment rdf:type owl:Class ;
                                             rdfs:subClassOf [ owl:intersectionOf ( <http://snomed.info/id/298054002>
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://purl.org/biotop/btl2.owl#isIncludedIn> ;
                                                                                      owl:someValuesFrom <http://snomed.info/id/225728007>
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ;
                                             rdfs:comment "Modeled in the ontology as the SNOMED CT concept \"Seen on arrival (finding)\" whose inclusion context is the SNOMED CT concept \"Accident and Emergency department (environment)\"."@en ;
                                             skos:altLabel "Admission Arrival Emergency Department"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionArrivalMode
resqplus:AdmissionArrivalMode rdf:type owl:Class ;
                              rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalProcedureStatement> ,
                                              [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalProcedureStatement>
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                                       owl:someValuesFrom <http://snomed.info/id/32485007>
                                                                     ]
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#procedureContext> ;
                                                                       owl:someValuesFrom resqplus:StatementProcedureQualifierValueSet
                                                                     ]
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#representsProcedure> ;
                                                                       owl:someValuesFrom resqplus:AdmissionArrivalModeValueSet
                                                                     ]
                                                                     [ rdf:type owl:Restriction ;
                                                                       owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#temporalContext> ;
                                                                       owl:someValuesFrom <http://snomed.info/id/410511007>
                                                                     ]
                                                                   ) ;
                                                rdf:type owl:Class
                                              ] ;
                              rdfs:comment "The pathway of patient's arrival to the reporting hospital."@en ;
                              skos:altLabel "Admission arrival mode"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionArrivalModeValueSet
resqplus:AdmissionArrivalModeValueSet rdf:type owl:Class ;
                                      rdfs:subClassOf [ rdf:type owl:Class ;
                                                        owl:unionOf ( resqplus:TransportationByEMSFromGP
                                                                      resqplus:TransportationByEMSFromHome_Scene_Hospital
                                                                      resqplus:TransportationByPrivateFromGP
                                                                      resqplus:TransportationByPrivateFromHome_Scene_Hospital
                                                                      resqplus:TransportationFromAnotherHospital
                                                                      resqplus:TransportationFromStrokeCenter
                                                                    )
                                                      ] ;
                                      rdfs:comment "Value set for \"Admission arrival mode\", covering 6 permissible values (e.g. Transportation By EMS From GP, Transportation By EMS From Home Scene Hospital, Transportation By Private From GP, among 3 others)."@en ;
                                      skos:altLabel "Admission Arrival Mode Value Set"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionArrivalOtherDepartment
resqplus:AdmissionArrivalOtherDepartment rdf:type owl:Class ;
                                         rdfs:subClassOf [ owl:intersectionOf ( <http://snomed.info/id/298054002>
                                                                                [ rdf:type owl:Restriction ;
                                                                                  owl:onProperty <http://purl.org/biotop/btl2.owl#isIncludedIn> ;
                                                                                  owl:someValuesFrom <http://snomed.info/id/284548004>
                                                                                ]
                                                                              ) ;
                                                           rdf:type owl:Class
                                                         ] ;
                                         rdfs:comment "Modeled in the ontology as the SNOMED CT concept \"Seen on arrival (finding)\" whose inclusion context is the SNOMED CT concept \"Hospital department (environment)\"."@en ;
                                         skos:altLabel "Admission Arrival Other Department"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionArrivalOutpatientFacility
resqplus:AdmissionArrivalOutpatientFacility rdf:type owl:Class ;
                                            rdfs:subClassOf [ owl:intersectionOf ( <http://snomed.info/id/298054002>
                                                                                   [ rdf:type owl:Restriction ;
                                                                                     owl:onProperty <http://purl.org/biotop/btl2.owl#isIncludedIn> ;
                                                                                     owl:someValuesFrom <http://snomed.info/id/33022008>
                                                                                   ]
                                                                                 ) ;
                                                              rdf:type owl:Class
                                                            ] ;
                                            rdfs:comment "Modeled in the ontology as the SNOMED CT concept \"Seen on arrival (finding)\" whose inclusion context is the SNOMED CT concept \"Hospital-based outpatient department (environment)\"."@en ;
                                            skos:altLabel "Admission Arrival Outpatient Facility"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionArrivalRadiologyDepartment
resqplus:AdmissionArrivalRadiologyDepartment rdf:type owl:Class ;
                                             rdfs:subClassOf [ owl:intersectionOf ( <http://snomed.info/id/298054002>
                                                                                    [ rdf:type owl:Restriction ;
                                                                                      owl:onProperty <http://purl.org/biotop/btl2.owl#isIncludedIn> ;
                                                                                      owl:someValuesFrom <http://snomed.info/id/309964003>
                                                                                    ]
                                                                                  ) ;
                                                               rdf:type owl:Class
                                                             ] ;
                                             rdfs:comment "Modeled in the ontology as the SNOMED CT concept \"Seen on arrival (finding)\" whose inclusion context is the SNOMED CT concept \"Radiology department (environment)\"."@en ;
                                             skos:altLabel "Admission Arrival Radiology Department"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionDate
resqplus:AdmissionDate rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement> ,
                                       [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement>
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservable> ;
                                                                owl:someValuesFrom <http://snomed.info/id/399423000>
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#hasObservableValue> ;
                                                                owl:someValuesFrom [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#QuantitativeResultValue>
                                                                                                          [ rdf:type owl:Restriction ;
                                                                                                            owl:onProperty <http://purl.org/biotop/btl2.owl#hasValue> ;
                                                                                                            owl:someValuesFrom xsd:dateTime
                                                                                                          ]
                                                                                                        ) ;
                                                                                     rdf:type owl:Class
                                                                                   ]
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                                owl:someValuesFrom <http://snomed.info/id/32485007>
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#situationContext> ;
                                                                owl:someValuesFrom resqplus:StatementFindingQualifierValueSet
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#temporalContext> ;
                                                                owl:someValuesFrom <http://snomed.info/id/410511007>
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                       rdfs:comment "Modeled in the ontology as an observation-result statement whose observable is the SNOMED CT concept \"Date of admission (observable entity)\"; and whose result value is a quantitative result value whose value is a date and time; and whose result of is the SNOMED CT concept \"Hospital admission (procedure)\"; and whose situation context is a statement finding qualifier value set; and whose temporal context is the SNOMED CT concept \"Current or past (actual) (qualifier value)\"."@en ;
                       skos:altLabel "Admission Date"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionDepartmentValueSet
resqplus:AdmissionDepartmentValueSet rdf:type owl:Class ;
                                     rdfs:subClassOf [ rdf:type owl:Class ;
                                                       owl:unionOf ( <http://snomed.info/id/305351004>
                                                                     <http://snomed.info/id/305379005>
                                                                     <http://snomed.info/id/305425002>
                                                                     <http://snomed.info/id/772011000>
                                                                     resqplus:AdmissionToOtherDepartment
                                                                   )
                                                     ] ;
                                     rdfs:comment "Value set for \"Admission patient department\", covering 5 permissible values (e.g. \"Admission to intensive care unit (procedure)\", \"Admission to neurology department (procedure)\", \"Admission to neurosurgical department (procedure)\", among 2 others)."@en ;
                                     skos:altLabel "Admission Department Value Set"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionEMSPrenotification
resqplus:AdmissionEMSPrenotification rdf:type owl:Class ;
                                     rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalProcedureStatement> ,
                                                     [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                                              owl:someValuesFrom <http://snomed.info/id/32485007>
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#representsProcedure> ;
                                                                              owl:someValuesFrom resqplus:EMSPrenotification
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#situationContext> ;
                                                                              owl:someValuesFrom resqplus:StatementProcedureQualifierValueSet
                                                                            ]
                                                                            [ rdf:type owl:Restriction ;
                                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#temporalContext> ;
                                                                              owl:someValuesFrom <http://snomed.info/id/410511007>
                                                                            ]
                                                                          ) ;
                                                       rdf:type owl:Class
                                                     ] ;
                                     rdfs:comment "Prenotification of the reporting hospital about stroke case arrival by EMS or ambulance."@en ;
                                     skos:altLabel "Admission EMS prenotification"@en .


###  http://www.semanticweb.org/catimc/resqplus#AdmissionExaminationBloodPressure
resqplus:AdmissionExaminationBloodPressure rdf:type owl:Class ;
                                           rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement> ,
                                                           [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ObservationResultStatement>
                                                                                  [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty <http://purl.org/biotop/btl2.owl#isPartOf> ;
                                                                                                           owl:someValuesFrom <http://snomed.info/id/32485007>
                                                                                                         ]
                                                                                                         [ rdf:type owl:Restriction ;
                                                                                                           owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
