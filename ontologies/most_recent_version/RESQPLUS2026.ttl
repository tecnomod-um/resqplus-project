@prefix : <http://resqplus-resources/ontologies/resqplus#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix resqplus: <http://www.semanticweb.org/catimc/resqplus#> .
@base <http://resqplus-resources/ontologies/resqplus#> .

<http://resqplus-resources/ontologies/resqplus> rdf:type owl:Ontology ;
                                                 owl:versionIRI <http://resqplus-resources/ontologies/resqplus/2023/1.0> ;
                                                 owl:imports <http://purl.org/biotop/btl2.owl> ,
                                                             <http://www.semanticweb.org/catimc/SemanticCommonDataModel> ;
                                                 <http://purl.org/dc/elements/1.1/title> "The RES-Q+ ontology for stroke disease" .

#################################################################
#    Annotation properties
#################################################################

###  http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled
<http://swrl.stanford.edu/ontologies/3.3/swrla.owl#isRuleEnabled> rdf:type owl:AnnotationProperty .

###  http://www.w3.org/2004/02/skos/core#altLabel
skos:altLabel rdf:type owl:AnnotationProperty .

#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/catimc/resqplus#caseId
resqplus:caseId rdf:type owl:DatatypeProperty ;
                rdfs:domain resqplus:ClinicalCase ;
                rdfs:range xsd:string .


###  http://www.semanticweb.org/catimc/resqplus#collectionMethod
resqplus:collectionMethod rdf:type owl:DatatypeProperty ;
                          rdfs:domain resqplus:ResqplusSource ;
                          rdfs:range xsd:string .


###  http://www.semanticweb.org/catimc/resqplus#datasetId
resqplus:datasetId rdf:type owl:DatatypeProperty ;
                   rdfs:domain resqplus:ResqplusSource ;
                   rdfs:range xsd:string .


###  http://www.semanticweb.org/catimc/resqplus#localization
resqplus:localization rdf:type owl:DatatypeProperty ;
                      rdfs:domain resqplus:ResqplusSource ;
                      rdfs:range xsd:string .


###  http://www.semanticweb.org/catimc/resqplus#providerDepartment
resqplus:providerDepartment rdf:type owl:DatatypeProperty ;
                            rdfs:domain resqplus:ResqplusProvider ;
                            rdfs:range xsd:string .


###  http://www.semanticweb.org/catimc/resqplus#providerHospitalType
resqplus:providerHospitalType rdf:type owl:DatatypeProperty ;
                              rdfs:domain resqplus:ResqplusProvider ;
                              rdfs:range xsd:string .


###  http://www.semanticweb.org/catimc/resqplus#providerId
resqplus:providerId rdf:type owl:DatatypeProperty ;
                    rdfs:domain resqplus:ResqplusProvider ;
                    rdfs:range xsd:string .


###  http://www.semanticweb.org/catimc/resqplus#sourceId
resqplus:sourceId rdf:type owl:DatatypeProperty ;
                  rdfs:domain resqplus:ResqplusSource ;
                  rdfs:range xsd:string .


#################################################################
#    Classes
#################################################################

###  http://snomed.info/id/1290004001
<http://snomed.info/id/1290004001> rdf:type owl:Class .


###  http://snomed.info/id/15240007
<http://snomed.info/id/15240007> rdf:type owl:Class .


