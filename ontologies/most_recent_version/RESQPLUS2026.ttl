###  http://www.semanticweb.org/catimc/resqplus#NeurosurgeryICHValueSet
resqplus:NeurosurgeryICHValueSet rdf:type owl:Class ;
                                 rdfs:subClassOf [ rdf:type owl:Class ;
                                                   owl:unionOf ( <http://snomed.info/id/10458001>
                                                                 <http://snomed.info/id/1288015005>
                                                                 <http://snomed.info/id/230869001>
                                                                 resqplus:MinInvasiveEvacuation
                                                                 resqplus:OpenCraniectomyEvacuation
                                                                 resqplus:StereotaticAspiration
                                                               )
                                                 ] ;
                                 rdfs:comment "Value set for \"ICH neuro surgery\", covering 6 permissible values (e.g. \"Evacuation of intracerebral hematoma (procedure)\", \"Decompressive craniectomy (procedure)\", \"External drainage procedure from ventricle of brain (procedure)\", among 3 others)."@en ;
                                 skos:altLabel "Neurosurgery ICH Value Set"@en .


###  http://www.semanticweb.org/catimc/resqplus#NeurosurgeryNotAvailable
resqplus:NeurosurgeryNotAvailable rdf:type owl:Class ;
                                  rdfs:subClassOf [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalSituationStatement>
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#representsSituation> ;
                                                                           owl:someValuesFrom <http://snomed.info/id/309987006>
                                                                         ]
                                                                       ) ;
                                                    rdf:type owl:Class
                                                  ] ;
                                  rdfs:comment "Modeled in the ontology as a clinical-situation statement whose represented situation is the SNOMED CT concept \"Neurosurgical department (environment)\"."@en ;
                                  skos:altLabel "Neurosurgery Not Available"@en .


###  http://www.semanticweb.org/catimc/resqplus#NimodipineAdm
resqplus:NimodipineAdm rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalProcedureStatement> ,
                                       [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                                owl:someValuesFrom <http://snomed.info/id/277132007>
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#representsProcedure> ;
                                                                owl:someValuesFrom resqplus:NimodipineAdminProcedure
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#situationContext> ;
                                                                owl:someValuesFrom resqplus:StatementProcedureQualifierValueSet
                                                              ]
                                                              [ rdf:type owl:Restriction ;
                                                                owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#temporalContext> ;
                                                                owl:someValuesFrom <http://snomed.info/id/410511007>
                                                              ]
                                                            ) ;
                                         rdf:type owl:Class
                                       ] ;
                       rdfs:comment "Administration of nimodipine to a subarachnoid hemorrhage patient, and the time interval in which it was administered."@en ;
                       skos:altLabel "Nimodipine adm"@en .


###  http://www.semanticweb.org/catimc/resqplus#NimodipineAdminProcedure
resqplus:NimodipineAdminProcedure rdf:type owl:Class ;
                                  rdfs:subClassOf [ owl:intersectionOf ( <http://snomed.info/id/18629005>
                                                                         [ rdf:type owl:Restriction ;
                                                                           owl:onProperty <http://snomed.info/id/609096000> ;
                                                                           owl:someValuesFrom [ rdf:type owl:Restriction ;
                                                                                                owl:onProperty <http://snomed.info/id/363701004> ;
                                                                                                owl:someValuesFrom <http://snomed.info/id/387502003>
                                                                                              ]
                                                                         ]
                                                                       ) ;
                                                    rdf:type owl:Class
                                                  ] ;
                                  rdfs:comment "Modeled in the ontology as the SNOMED CT concept \"Administration of drug or medicament (procedure)\" whose role group is something whose direct substance is the SNOMED CT concept \"Nimodipine (substance)\"."@en ;
                                  skos:altLabel "Nimodipine Admin Procedure"@en .


###  http://www.semanticweb.org/catimc/resqplus#NoAngiography
resqplus:NoAngiography rdf:type owl:Class ;
                       rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalProcedureNotDoneStatement> ;
                       rdfs:comment "Modeled in the ontology as a clinical procedure not done statement."@en ;
                       skos:altLabel "No Angiography"@en .


###  http://www.semanticweb.org/catimc/resqplus#NoAnticoagulantReasonValueSet
resqplus:NoAnticoagulantReasonValueSet rdf:type owl:Class ;
                                       rdfs:subClassOf [ rdf:type owl:Class ;
                                                         owl:unionOf ( resqplus:AntidoteNotLicensed
                                                                       resqplus:ConsentNotGiven
                                                                       resqplus:CostOfTreatment
                                                                       resqplus:CriteriaNotMet
                                                                       resqplus:DrugNotAvailable
                                                                       resqplus:ForgetMedication
                                                                     )
                                                       ] ;
                                       rdfs:comment "Value set for \"Anticoagulant antidote admin\", covering 6 permissible values (e.g. Antidote Not Licensed, Consent Not Given, Cost Of Treatment, among 3 others)."@en ;
                                       skos:altLabel "No Anticoagulant Reason Value Set"@en .


###  http://www.semanticweb.org/catimc/resqplus#NoICHReasonValueSet
resqplus:NoICHReasonValueSet rdf:type owl:Class ;
                             rdfs:subClassOf [ rdf:type owl:Class ;
                                               owl:unionOf ( resqplus:ConsentNotGiven
                                                             resqplus:CostOfTreatment
                                                             resqplus:HematomaLocation
                                                             resqplus:NeurosurgeryNotAvailable
                                                             resqplus:OtherReasonForNoICH
                                                             resqplus:PoorPrognosis
                                                             resqplus:SizeContraindication
                                                             resqplus:SpecialistNotAvailable
                                                           )
                                             ] ;
                             rdfs:comment "Value set for \"ICH neuro surgery\", covering 8 permissible values (e.g. Consent Not Given, Cost Of Treatment, Hematoma Location, among 5 others)."@en ;
                             skos:altLabel "No ICH Reason Value Set"@en .


###  http://www.semanticweb.org/catimc/resqplus#NoResponse
resqplus:NoResponse rdf:type owl:Class ;
                    rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalStatement> ;
                    rdfs:comment "Modeled in the ontology as a clinical statement."@en ;
                    skos:altLabel "No Response"@en .


###  http://www.semanticweb.org/catimc/resqplus#NonSmoker
resqplus:NonSmoker rdf:type owl:Class ;
                   rdfs:subClassOf [ owl:intersectionOf ( <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalStatement>
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#representsSituation> ;
                                                            owl:someValuesFrom <http://snomed.info/id/77176002>
                                                          ]
                                                          [ rdf:type owl:Restriction ;
                                                            owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#situationContext> ;
                                                            owl:someValuesFrom <http://snomed.info/id/410516002>
                                                          ]
                                                        ) ;
                                     rdf:type owl:Class
                                   ] ;
                   rdfs:comment "Modeled in the ontology as a clinical statement whose represented situation is the SNOMED CT concept \"Smoker (finding)\"; and whose situation context is the SNOMED CT concept \"Known absent (qualifier value)\"."@en ;
                   skos:altLabel "Non Smoker"@en .


###  http://www.semanticweb.org/catimc/resqplus#NotContacted
resqplus:NotContacted rdf:type owl:Class ;
                      rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalStatement> ;
                      rdfs:comment "Modeled in the ontology as a clinical statement."@en ;
                      skos:altLabel "Not Contacted"@en .


###  http://www.semanticweb.org/catimc/resqplus#Nurse
resqplus:Nurse rdf:type owl:Class ;
               rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#HealthcareProfessional> ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty <http://purl.org/biotop/btl2.owl#isBearerOf> ;
                                 owl:someValuesFrom <http://snomed.info/id/265937000>
                               ] ;
               rdfs:comment "Modeled in the ontology as a healthcare professional; and as something whose bearer is the SNOMED CT concept \"Nursing occupation (occupation)\"."@en ;
               skos:altLabel "Nurse"@en .


###  http://www.semanticweb.org/catimc/resqplus#OldInfarcts
resqplus:OldInfarcts rdf:type owl:Class ;
                     rdfs:subClassOf <http://www.semanticweb.org/catimc/SemanticCommonDataModel#ClinicalSituationStatement> ,
                                     [ owl:intersectionOf ( [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#isResultOf> ;
                                                              owl:someValuesFrom <http://snomed.info/id/165197003>
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#representsSituation> ;
                                                              owl:someValuesFrom resqplus:OldInfarctsValueSet
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#situationContext> ;
                                                              owl:someValuesFrom resqplus:StatementFindingQualifierValueSet
                                                            ]
                                                            [ rdf:type owl:Restriction ;
                                                              owl:onProperty <http://www.semanticweb.org/catimc/SemanticCommonDataModel#temporalContext> ;
                                                              owl:someValuesFrom <http://snomed.info/id/410511007>
                                                            ]
                                                          ) ;
                                       rdf:type owl:Class
                                     ] ;
                     rdfs:comment "A pre-existing (old) brain infarct observed on the first CT/MR brain image, in a specific location (cortical, subcortical, or brainstem) or overall."@en ;
                     skos:altLabel "Old infarcts"@en .


###  http://www.semanticweb.org/catimc/resqplus#OldInfarctsValueSet
resqplus:OldInfarctsValueSet rdf:type owl:Class ;
                             rdfs:subClassOf [ rdf:type owl:Class ;
                                               owl:unionOf ( <http://snomed.info/id/432504007>
                                                             resqplus:BrainStemInfarct
                                                             resqplus:CorticalInfarct
                                                             resqplus:SubcorticalInfarct
                                                           )
                                             ] ;
                             rdfs:comment "Value set for \"Old infarcts\", covering 4 permissible values (e.g. \"Cerebral infarction (disorder)\", Brain Stem Infarct, Cortical Infarct, among 1 others)."@en ;
                             skos:altLabel "Old Infarcts Value Set"@en .


###  http://www.semanticweb.org/catimc/resqplus#OpenCraniectomyEvacuation
