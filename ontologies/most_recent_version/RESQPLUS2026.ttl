                                                     rdf:type owl:Class
                                                   ] ;
                                   rdfs:comment "A medication (antiplatelet, anticoagulant, antihypertensive, antidiabetic, or statin) prescribed to the patient at hospital discharge, or the reason if an indicated anticoagulant was not prescribed."@en ;
                                   skos:altLabel "Discharge prescription drug"@en .


